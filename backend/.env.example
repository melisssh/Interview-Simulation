# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- JWT (minimum 32 random characters) ---
JWT_SECRET_KEY=your-very-long-random-secret-key-here

# --- Database (Supabase Postgres, psycopg3 driver) ---
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
FRONTEND_BASE_URL=http://localhost:5173

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b           # used for real-time interview (WebSocket)
OLLAMA_ANALYSIS_MODEL=qwen2.5:7b   # used for post-interview feedback analysis

# --- Resend (email sending) - Optional ---
# Without this, email verification will not work in production.
# On the free tier you can only send from a verified domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# --- Dev mode: auto-verify new users when email is not configured ---
DEV_AUTO_VERIFY=true

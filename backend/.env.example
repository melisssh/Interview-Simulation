# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- JWT (minimum 32 random characters) ---
JWT_SECRET_KEY=your-very-long-random-secret-key-here

# --- Database (PostgreSQL, psycopg3 driver) ---
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
FRONTEND_BASE_URL=http://localhost:5173

# --- Ollama (local LLM) ---
# If running via Docker, use: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_ANALYSIS_MODEL=qwen2.5:7b
# OLLAMA_TEMPERATURE=0.55

# --- SMTP (email verification and password reset) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@example.com

# --- Local development only: skip email verification requirement on new users ---
# Registration still attempts to send verification email (SMTP must work).
DEV_AUTO_VERIFY=false
